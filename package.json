{
  "name": "geras-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "server"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "dev:mobile-familia": "turbo dev --filter=mobile-familia",
    "dev:mobile-profesional": "turbo dev --filter=mobile-profesional",
    "dev:admin": "turbo dev --filter=admin-panel",
    "dev:server": "turbo dev --filter=server"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "npm@10.8.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
